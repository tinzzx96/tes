generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  student
  teacher
  admin
  proctor
}

enum ExamStatus {
  draft
  active
  completed
}

enum AttemptStatus {
  waiting
  started
  submitted
}

enum QuestionType {
  multiple_choice
  essay
}

// ─── Models ──────────────────────────────────────────────────────────────────

// Tingkat kelas: X, XI, XII
model Grade {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(10)  // "X" | "XI" | "XII"
  label     String   @db.VarChar(50)           // "Kelas X" | "Kelas XI" | "Kelas XII"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes   Class[]

  @@map("grades")
}

// Rombongan belajar (cth: XI RPL 1, XI TKJ 2)
model Class {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)  // "XI RPL 1"
  gradeId   Int      @map("grade_id")
  major     String?  @db.VarChar(50)           // "RPL" | "TKJ" | "MM"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  grade       Grade       @relation(fields: [gradeId], references: [id])
  users       User[]
  examClasses ExamClass[]

  @@map("classes")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  nisn      String   @unique @db.VarChar(20)
  password  String   @db.VarChar(255)
  class     String?  @db.VarChar(20)    // legacy label, tetap ada
  classId   Int?     @map("class_id")   // FK ke tabel classes
  device    String?  @db.VarChar(100)
  room      String?  @db.VarChar(20)    // legacy room name
  roomId    Int?     @map("room_id")    // FK ke master data room
  role      Role     @default(student)
  verified  Boolean  @default(false)
  academicYear String?  @map("academic_year") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classRef      Class?         @relation(fields: [classId], references: [id], onDelete: SetNull)
  roomRef       Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  taughtExams   Exam[]         @relation("TeacherExams")
  questionBanks QuestionBank[] @relation("BankCreator")
  examAttempts  ExamAttempt[]
  answers       Answer[]
  proctorSessions Session[]    @relation("ProctorSessions")
  activityLogs    ActivityLog[] @relation("UserActivityLogs")


  @@map("users")
}

model QuestionBank {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  subject   String   @db.VarChar(100)
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator   User       @relation("BankCreator", fields: [createdBy], references: [id])
  questions Question[]
  exams     Exam[]

  @@map("question_banks")
}

model Exam {
  id              Int        @id @default(autoincrement())
  title           String     @db.VarChar(255)
  subject         String     @db.VarChar(100)
  teacherId       Int        @map("teacher_id")
  // Wajib: FK ke question_banks agar server tahu mau narik soal dari bank mana
  questionBankId  Int?       @map("question_bank_id")
  durationMinutes Int        @default(90) @map("duration_minutes")
  startTime       DateTime   @map("start_time")
  endTime         DateTime   @map("end_time")
  examCode        String     @unique @db.VarChar(20) @map("exam_code")
  token           String     @unique @db.VarChar(10)
  status          ExamStatus @default(draft)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  teacher      User          @relation("TeacherExams", fields: [teacherId], references: [id])
  questionBank QuestionBank? @relation(fields: [questionBankId], references: [id])
  attempts     ExamAttempt[]
  answers      Answer[]
  examTokens   ExamToken[]
  examClasses  ExamClass[]   // relasi ke pivot exam_classes

  @@map("exams")
}

// Pivot many-to-many: ujian ↔ kelas peserta
model ExamClass {
  id        Int      @id @default(autoincrement())
  examId    Int      @map("exam_id")
  classId   Int      @map("class_id")
  createdAt DateTime @default(now()) @map("created_at")

  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([examId, classId])
  @@map("exam_classes")
}

model Question {
  id             Int          @id @default(autoincrement())
  questionBankId Int          @map("question_bank_id")
  body           String       @db.Text
  // Hanya simpan nama file / path. DILARANG menyimpan base64 di sini.
  // Contoh valid: "soal_mtk_1.jpg", bukan data:image/...
  questionImage  String?      @db.VarChar(255) @map("question_image")
  type           QuestionType @default(multiple_choice)
  orderNum       Int          @default(1) @map("order_num")
  points         Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  questionBank QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  options      Option[]
  answers      Answer[]

  @@map("questions")
}

model Option {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  body       String   @db.Text
  isCorrect  Boolean  @default(false) @map("is_correct")
  orderNum   Int      @default(1) @map("order_num")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@map("options")
}

// Tabel utama untuk tracking sesi ujian per siswa.
// Menggabungkan fungsi student_exams + results + fitur keamanan baru.
model ExamAttempt {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  examId      Int           @map("exam_id")
  status      AttemptStatus @default(waiting)
  startedAt   DateTime?     @map("started_at")
  finishedAt  DateTime?     @map("finished_at")
  score       Float?
  deviceId    String?       @db.VarChar(100) @map("device_id")
  ipAddress   String?       @db.VarChar(45)  @map("ip_address")

  // ── Fitur Keamanan Anti-Curang ──────────────────────────────────────
  // Jumlah pelanggaran (misal: lepas screen pinning). Auto-submit saat >= 5.
  counterPelanggaran Int     @default(0) @map("counter_pelanggaran")
  // PIN acak dari server yang dikirim ke pengawas via WebSocket (emitPinGenerated).
  // Diketik siswa di HP untuk membuka blokir. Dihapus (set null) setelah terpakai (one-time use).
  unlockPin          String? @db.VarChar(10) @map("unlock_pin")
  
  // Tracking nomor soal yang sedang dibuka/dikerjakan siswa (1-based index)
  currentQuestion    Int     @default(1) @map("current_question")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam    Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@unique([userId, examId])
  @@index([status, updatedAt])  // offline detection & sessionCleanup job
  @@index([examId])             // getParticipants per ujian
  @@map("exam_attempts")
}

// Token akses ujian per exam — divalidasi siswa sebelum masuk ExamPlayerScreen.
// Satu exam bisa punya satu token aktif, dikelola admin/guru.
model ExamToken {
  id        Int      @id @default(autoincrement())
  examId    Int      @map("exam_id")
  token     String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, token])
  @@map("exam_tokens")
}

model Room {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  maxCapacity Int       @map("max_capacity")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  users       User[]
  sessions    Session[]

  @@map("rooms")
}

// Token sesi login — divalidasi SEKALI saat login, dikelola admin.
// Menghindari siswa login di luar lingkungan ujian yang terkontrol.
model Session {
  id          Int       @id @default(autoincrement())
  token       String    @unique @db.VarChar(20)
  description String?   @db.VarChar(255)
  roomId      Int       @map("room_id")
  proctorId   Int?      @map("proctor_id")
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")

  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  proctor     User?     @relation("ProctorSessions", fields: [proctorId], references: [id], onDelete: SetNull)

  @@map("sessions")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")         // null = sistem
  actorName   String   @db.VarChar(255) @map("actor_name")
  actorRole   String   @db.VarChar(20)  @map("actor_role")
  action      String   @db.VarChar(100)        // "CREATE_EXAM" | "UPDATE_EXAM" | "DELETE_USER" dll
  targetType  String?  @db.VarChar(50)  @map("target_type")  // "exam" | "user" | "session"
  targetId    Int?     @map("target_id")
  targetLabel String?  @db.VarChar(255) @map("target_label") // nama ujian/user yg dikenai aksi
  meta        Json?                             // data tambahan opsional (JSON)
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("activity_logs")
}

model Answer {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  examId      Int       @map("exam_id")
  questionId  Int       @map("question_id")
  attemptId   Int       @map("attempt_id")
  optionId    Int?      @map("option_id")
  essayAnswer String?   @db.Text @map("essay_answer")
  savedAt     DateTime? @map("saved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam     Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  option   Option?     @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([userId, examId, questionId])
  @@index([examId, questionId])  // auto-save row-level lock lookup
  @@map("answers")
}
